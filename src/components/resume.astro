---
import { data, genericData, Language } from "../data/data";
import {
    FaArrowRight,
    FaBriefcase,
    FaCheckCircle,
    FaDownload,
    FaEnvelope,
    FaGraduationCap,
    FaLinkedin,
    FaMapMarkerAlt,
    FaMicrochip,
    FaTools
} from "react-icons/fa";

const { lang, variant = "default" } = Astro.props;
const siteData = lang === Language.NL ? data.nl : data.en;
const contactHref = `mailto:${genericData.contact.email}`;
const isPrint = variant === "print";
const labels = lang === Language.NL
    ? {
        consultingFit: "Geschikt voor",
        consultingDescription: "Ideaal voor CTO's en engineering teams die senior ownership nodig hebben over architectuur, delivery, cloudfundamenten en industriële systeemintegratie.",
        challenge: "Uitdaging",
        solution: "Oplossing",
        technologies: "Technologieën",
        result: "Resultaat",
        trustedPartner: "Betrouwbare technische partner"
    }
    : {
        consultingFit: "Consulting fit",
        consultingDescription: "Best suited for CTOs and engineering teams that need senior ownership across architecture, delivery, cloud foundations, and industrial system integration.",
        challenge: "Challenge",
        solution: "Solution",
        technologies: "Technologies",
        result: "Result",
        trustedPartner: "Trusted technical partner"
    };
---

<div class={`cv-print-root flex flex-col ${isPrint ? "gap-5" : "gap-8 md:gap-12"}`}>
    <section class={`avoid-page-break relative overflow-hidden border border-slate-200 bg-[radial-gradient(circle_at_top_left,rgba(49,106,212,0.22),transparent_34%),linear-gradient(135deg,#0f172a_0%,#132238_45%,#1f4f8f_100%)] text-white ${isPrint ? "rounded-[1.75rem] px-5 py-6 shadow-[0_18px_50px_rgba(15,23,42,0.22)]" : "rounded-4xl px-6 py-8 shadow-[0_30px_80px_rgba(15,23,42,0.28)] sm:px-8 lg:px-10 lg:py-10"}`}>
        <div class="absolute inset-0 bg-[linear-gradient(120deg,transparent,rgba(255,255,255,0.07),transparent)]" />
        <div class={`relative grid lg:items-start ${isPrint ? "gap-5 lg:grid-cols-[1.2fr_0.85fr]" : "gap-8 lg:grid-cols-[1.4fr_0.85fr]"}`}>
            <div class={isPrint ? "space-y-4" : "space-y-6"}>
                <div class="inline-flex items-center gap-2 rounded-full border border-white/15 bg-white/10 px-4 py-2 text-xs font-semibold uppercase tracking-[0.22em] text-sky-100">
                    <span class="h-2 w-2 rounded-full bg-emerald-400" />
                    {siteData.hero.eyebrow}
                </div>

                <div class={`max-w-3xl ${isPrint ? "space-y-3" : "space-y-4"}`}>
                    <h1 class={`max-w-2xl font-semibold tracking-tight text-balance ${isPrint ? "text-3xl sm:text-4xl lg:text-5xl" : "text-4xl sm:text-5xl lg:text-6xl"}`}>
                        {siteData.hero.title}
                    </h1>
                    <p class={`max-w-2xl text-slate-200 ${isPrint ? "text-sm leading-7 sm:text-base" : "text-base leading-8 sm:text-lg"}`}>
                        {siteData.hero.subtitle}
                    </p>
                    <p class="inline-flex items-center gap-2 rounded-full bg-emerald-400/15 px-4 py-2 text-sm font-medium text-emerald-100 ring-1 ring-inset ring-emerald-300/30">
                        <span class="h-2 w-2 rounded-full bg-emerald-300" />
                        {siteData.hero.availability}
                    </p>
                </div>

                <div class={`flex flex-col gap-3 sm:flex-row sm:flex-wrap ${isPrint ? "hidden" : ""}`}>
                    <a
                        href={contactHref}
                        class="inline-flex items-center justify-center gap-2 rounded-full bg-white px-5 py-3 text-sm font-semibold text-slate-900 no-underline transition hover:-translate-y-0.5 hover:bg-slate-100"
                    >
                        <FaEnvelope className="h-4 w-4" />
                        {siteData.hero.primaryCta}
                    </a>
                    <a
                        href={genericData.contact.linkedin}
                        target="_blank"
                        rel="noreferrer"
                        class="inline-flex items-center justify-center gap-2 rounded-full border border-white/20 bg-white/10 px-5 py-3 text-sm font-semibold text-white no-underline transition hover:-translate-y-0.5 hover:bg-white/15"
                    >
                        <FaLinkedin className="h-4 w-4" />
                        {siteData.hero.secondaryCta}
                    </a>
                    <a
                        href={genericData.contact.cvPaths[lang as Language]}
                        class="inline-flex items-center justify-center gap-2 rounded-full border border-sky-300/35 bg-sky-400/15 px-5 py-3 text-sm font-semibold text-sky-50 no-underline transition hover:-translate-y-0.5 hover:bg-sky-400/20"
                    >
                        <FaDownload className="h-4 w-4" />
                        {siteData.hero.tertiaryCta}
                    </a>
                </div>

                <ul class={`grid sm:grid-cols-2 ${isPrint ? "gap-2 pt-1" : "gap-3 pt-2"}`}>
                    {
                        siteData.valueProps.map((item) => (
                            <li class={`flex items-start gap-3 rounded-2xl border border-white/10 bg-white/[0.07] text-slate-100 backdrop-blur-sm ${isPrint ? "px-3 py-2.5 text-[13px] leading-6" : "px-4 py-3 text-sm"}`}>
                                <FaCheckCircle className="mt-0.5 h-4 w-4 shrink-0 text-emerald-300" />
                                <span>{item}</span>
                            </li>
                        ))
                    }
                </ul>
            </div>

            <aside class={`flex flex-col rounded-[1.75rem] border border-white/12 bg-white/10 backdrop-blur-md ${isPrint ? "gap-3 p-4" : "gap-4 p-5"}`}>
                <div class="flex items-center gap-4">
                    <img
                        src={genericData.profile.headshot}
                        alt={genericData.profile.name}
                        class={`rounded-2xl object-cover ring-2 ring-white/15 ${isPrint ? "h-18 w-18" : "h-20 w-20"}`}
                    />
                    <div>
                        <p class="text-xl font-semibold">{genericData.profile.name}</p>
                        <p class="mt-1 text-sm text-slate-200">{genericData.profile.location}</p>
                    </div>
                </div>

                <div class={`rounded-2xl border border-white/10 bg-slate-950/25 ${isPrint ? "p-3.5" : "p-4"}`}>
                    <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-300">
                        {labels.consultingFit}
                    </p>
                    <p class={`mt-2 text-slate-100 ${isPrint ? "text-[13px] leading-6" : "text-sm leading-7"}`}>
                        {labels.consultingDescription}
                    </p>
                </div>

                <div class={`text-sm text-slate-100 ${isPrint ? "space-y-2.5" : "space-y-3"}`}>
                    <div class="flex items-start gap-3">
                        <FaMapMarkerAlt className="mt-1 h-4 w-4 shrink-0 text-sky-200" />
                        <span>{genericData.contact.address.fullAddress}</span>
                    </div>
                    <div class="flex items-start gap-3">
                        <FaEnvelope className="mt-1 h-4 w-4 shrink-0 text-sky-200" />
                        <a href={contactHref} class="text-slate-100 no-underline hover:text-white">{genericData.contact.email}</a>
                    </div>
                    <div class="flex items-start gap-3">
                        <FaLinkedin className="mt-1 h-4 w-4 shrink-0 text-sky-200" />
                        <a
                            href={genericData.contact.linkedin}
                            target="_blank"
                            rel="noreferrer"
                            class="text-slate-100 no-underline hover:text-white"
                        >
                            {genericData.contact.linkedinLabel}
                        </a>
                    </div>
                </div>
            </aside>
        </div>
    </section>

    <section class={`avoid-page-break grid gap-4 ${isPrint ? "md:grid-cols-3 xl:grid-cols-5" : "md:grid-cols-2 xl:grid-cols-5"}`}>
        {
            siteData.trustIndicators.map((item) => (
                <article class={`rounded-3xl border border-slate-200 bg-white shadow-[0_14px_40px_rgba(15,23,42,0.06)] ${isPrint ? "p-4" : "p-5"}`}>
                    <p class="text-2xl font-semibold tracking-tight text-slate-900">{item.value}</p>
                    <p class="mt-2 text-sm font-semibold uppercase tracking-[0.16em] text-sky-700">
                        {item.label}
                    </p>
                    <p class="mt-3 text-sm leading-7 text-slate-600">{item.detail}</p>
                </article>
            ))
        }
    </section>

    <section class={`avoid-page-break rounded-[1.75rem] border border-slate-200 bg-white shadow-[0_18px_50px_rgba(15,23,42,0.06)] ${isPrint ? "p-5 sm:p-6" : "p-6 sm:p-8"}`}>
        <div class="flex items-center gap-3">
                <div class="rounded-2xl bg-sky-50 p-3 text-sky-700">
                    <FaBriefcase className="h-5 w-5" />
                </div>
            <h2 class="text-2xl font-semibold tracking-tight text-slate-900">{siteData.services.title}</h2>
        </div>
        <p class={`mt-4 max-w-2xl text-slate-600 ${isPrint ? "text-sm leading-7" : "text-base leading-8"}`}>
            {siteData.services.description}
        </p>
        <div class={`grid ${isPrint ? "mt-5 gap-3" : "mt-6 gap-4"}`}>
            {
                siteData.services.items.map((service) => (
                    <article class={`avoid-page-break rounded-[1.4rem] border border-slate-200 bg-slate-50/70 ${isPrint ? "p-4" : "p-5"}`}>
                        <h3 class="text-lg font-semibold text-slate-900">{service.name}</h3>
                        <p class="mt-3 text-sm leading-7 text-slate-600">{service.problem}</p>
                        <p class="mt-3 flex items-start gap-3 text-sm leading-7 text-slate-800">
                            <FaArrowRight className="mt-1 h-4 w-4 shrink-0 text-sky-700" />
                            <span>{service.outcome}</span>
                        </p>
                    </article>
                ))
            }
        </div>
    </section>

    <section class={`rounded-[1.75rem] border border-slate-200 bg-white shadow-[0_18px_50px_rgba(15,23,42,0.06)] ${isPrint ? "p-5 sm:p-6" : "p-6 sm:p-8"}`}>
        <div class="flex items-center gap-3">
            <div class="rounded-2xl bg-sky-50 p-3 text-sky-700">
                <FaMicrochip className="h-5 w-5" />
            </div>
            <div>
                <h2 class="text-2xl font-semibold tracking-tight text-slate-900">{siteData.projects.title}</h2>
                <p class={`mt-2 max-w-3xl text-slate-600 ${isPrint ? "text-sm leading-7" : "text-base leading-8"}`}>{siteData.projects.description}</p>
            </div>
        </div>
        <div class={`grid xl:grid-cols-2 ${isPrint ? "mt-6 gap-4" : "mt-8 gap-5"}`}>
            {
                siteData.projects.items.map((project) => (
                    <article class={`avoid-page-break rounded-3xl border border-slate-200 bg-slate-50/70 ${isPrint ? "p-5" : "p-6"}`}>
                        <h3 class="text-xl font-semibold text-slate-900">{project.name}</h3>
                        <dl class="mt-5 grid gap-4">
                            <div>
                                <dt class="text-xs font-semibold uppercase tracking-[0.16em] text-sky-700">{labels.challenge}</dt>
                                <dd class="mt-2 text-sm leading-7 text-slate-700">{project.challenge}</dd>
                            </div>
                            <div>
                                <dt class="text-xs font-semibold uppercase tracking-[0.16em] text-sky-700">{labels.solution}</dt>
                                <dd class="mt-2 text-sm leading-7 text-slate-700">{project.solution}</dd>
                            </div>
                            <div>
                                <dt class="text-xs font-semibold uppercase tracking-[0.16em] text-sky-700">{labels.technologies}</dt>
                                <dd class="mt-3 flex flex-wrap gap-2">
                                    {
                                        project.technologies.map((technology) => (
                                            <span class="rounded-full border border-slate-200 bg-white px-3 py-1 text-xs font-medium text-slate-700">
                                                {technology}
                                            </span>
                                        ))
                                    }
                                </dd>
                            </div>
                            <div>
                                <dt class="text-xs font-semibold uppercase tracking-[0.16em] text-sky-700">{labels.result}</dt>
                                <dd class="mt-2 text-sm leading-7 text-slate-900">{project.result}</dd>
                            </div>
                        </dl>
                    </article>
                ))
            }
        </div>
    </section>

    <section class={`rounded-[1.75rem] border border-slate-200 bg-white shadow-[0_18px_50px_rgba(15,23,42,0.06)] ${isPrint ? "p-5 sm:p-6" : "p-6 sm:p-8"}`}>
        <div class="flex items-center gap-3">
            <div class="rounded-2xl bg-sky-50 p-3 text-sky-700">
                <FaBriefcase className="h-5 w-5" />
            </div>
            <div>
                <h2 class="text-2xl font-semibold tracking-tight text-slate-900">{siteData.experience.title}</h2>
                <p class={`mt-2 max-w-3xl text-slate-600 ${isPrint ? "text-sm leading-7" : "text-base leading-8"}`}>{siteData.experience.description}</p>
            </div>
        </div>

        <div class={isPrint ? "mt-6 space-y-4" : "mt-8 space-y-6"}>
            {
                siteData.experience.roles.map((role) => (
                    <article class={`avoid-page-break rounded-3xl border border-slate-200 bg-slate-50/70 ${isPrint ? "p-5" : "p-6"}`}>
                        <div class="flex flex-col gap-3 md:flex-row md:items-start md:justify-between">
                            <div>
                                <h3 class="text-xl font-semibold text-slate-900">{role.title}</h3>
                                <p class="mt-1 text-sm font-medium text-sky-700">{role.company}</p>
                            </div>
                            <span class="inline-flex w-fit rounded-full bg-white px-4 py-2 text-xs font-semibold uppercase tracking-[0.14em] text-slate-600 ring-1 ring-slate-200">
                                {role.period}
                            </span>
                        </div>
                        <p class="mt-4 text-sm leading-7 text-slate-700">{role.summary}</p>
                        <ul class="mt-5 grid gap-3">
                            {
                                role.highlights.map((highlight) => (
                                    <li class="flex items-start gap-3 text-sm leading-7 text-slate-700">
                                        <FaCheckCircle className="mt-1 h-4 w-4 shrink-0 text-emerald-600" />
                                        <span>{highlight}</span>
                                    </li>
                                ))
                            }
                        </ul>
                    </article>
                ))
            }
        </div>
    </section>

    <section class={`avoid-page-break rounded-[1.75rem] border border-slate-200 bg-white shadow-[0_18px_50px_rgba(15,23,42,0.06)] ${isPrint ? "p-5 sm:p-6" : "p-6 sm:p-8"}`}>
        <div class="flex items-center gap-3">
            <div class="rounded-2xl bg-sky-50 p-3 text-sky-700">
                <FaTools className="h-5 w-5" />
            </div>
            <div>
                <h2 class="text-2xl font-semibold tracking-tight text-slate-900">{siteData.skills.title}</h2>
                <p class={`mt-2 text-slate-600 ${isPrint ? "text-sm leading-7" : "text-base leading-8"}`}>{siteData.skills.description}</p>
            </div>
        </div>

        <div class={`grid ${isPrint ? "mt-5 gap-3" : "mt-6 gap-4"}`}>
            {
                siteData.skills.groups.map((group) => (
                    <article class={`avoid-page-break rounded-[1.4rem] border border-slate-200 bg-slate-50/70 ${isPrint ? "p-4" : "p-5"}`}>
                        <div class="flex items-start justify-between gap-3">
                            <h3 class="text-base font-semibold uppercase tracking-[0.14em] text-slate-900">
                                {group.category}
                            </h3>
                        </div>
                        <p class="mt-2 text-sm leading-7 text-slate-600">{group.focus}</p>
                        <div class="mt-4 flex flex-wrap gap-2">
                            {
                                group.items.map((item) => (
                                    <span class="rounded-full bg-white px-3 py-1 text-xs font-medium text-slate-700 ring-1 ring-slate-200">
                                        {item}
                                    </span>
                                ))
                            }
                        </div>
                    </article>
                ))
            }
        </div>
    </section>

    <section class={`avoid-page-break rounded-[1.75rem] border border-slate-200 bg-white shadow-[0_18px_50px_rgba(15,23,42,0.06)] ${isPrint ? "p-5 sm:p-6" : "p-6 sm:p-8"}`}>
        <div class="flex items-center gap-3">
            <div class="rounded-2xl bg-sky-50 p-3 text-sky-700">
                <FaGraduationCap className="h-5 w-5" />
            </div>
            <h2 class="text-2xl font-semibold tracking-tight text-slate-900">{siteData.education.title}</h2>
        </div>
        <div class={`grid ${isPrint ? "mt-5 gap-3 md:grid-cols-2" : "mt-6 gap-4"}`}>
            {
                siteData.education.items.map((item) => (
                    <article class={`avoid-page-break rounded-[1.3rem] border border-slate-200 bg-slate-50/70 ${isPrint ? "p-4" : "p-5"}`}>
                        <h3 class="text-base font-semibold text-slate-900">{item.title}</h3>
                        <p class="mt-2 text-sm text-slate-700">{item.school}</p>
                        <p class="mt-1 text-xs font-semibold uppercase tracking-[0.14em] text-slate-500">{item.period}</p>
                    </article>
                ))
            }
        </div>
    </section>

    <section class={`rounded-[1.75rem] border border-slate-200 bg-[linear-gradient(135deg,#0f172a_0%,#153463_100%)] text-white shadow-[0_18px_50px_rgba(15,23,42,0.18)] ${isPrint ? "hidden" : "p-6 sm:p-8"}`}>
        <div class="flex flex-col gap-6 lg:flex-row lg:items-center lg:justify-between">
            <div class="max-w-3xl">
                <p class="text-xs font-semibold uppercase tracking-[0.2em] text-sky-200">{labels.trustedPartner}</p>
                <h2 class="mt-3 text-3xl font-semibold tracking-tight">{siteData.contact.title}</h2>
                <p class="mt-3 text-base leading-8 text-slate-200">{siteData.contact.description}</p>
            </div>
            <div class="flex flex-col gap-3 sm:flex-row">
                <a
                    href={contactHref}
                    class="inline-flex items-center justify-center gap-2 rounded-full bg-white px-5 py-3 text-sm font-semibold text-slate-900 no-underline transition hover:-translate-y-0.5 hover:bg-slate-100"
                >
                    <FaEnvelope className="h-4 w-4" />
                    {siteData.hero.primaryCta}
                </a>
                <a
                    href={genericData.contact.linkedin}
                    target="_blank"
                    rel="noreferrer"
                    class="inline-flex items-center justify-center gap-2 rounded-full border border-white/20 bg-white/10 px-5 py-3 text-sm font-semibold text-white no-underline transition hover:-translate-y-0.5 hover:bg-white/15"
                >
                    <FaLinkedin className="h-4 w-4" />
                    {siteData.hero.secondaryCta}
                </a>
            </div>
        </div>
    </section>
</div>
